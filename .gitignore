# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# typescript
*.tsbuildinfo
next-env.d.ts

# segredos: ADMIN_PASSWORD e SESSION_SECRET nunca vão para o repositório.
# .env.example é a exceção — é ele que documenta quais variáveis existem.
.env
.env.*
!.env.example

# Banco SQLite local — dados, nao codigo. Em producao vive num volume.
# data/catalog-export.json E versionado: e a origem da carga inicial.
/data/*.db
/data/*.db-wal
/data/*.db-shm

# Gerado pelo build (scripts/build-seed.ts) a partir do catalog-export.
/data/seed.json
