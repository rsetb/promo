# Conexão com o Postgres.
# No EasyPanel, use o hostname interno do serviço de banco (não exponha a porta
# 5432 para a internet — o app fala com o Postgres pela rede interna do Docker).
DATABASE_URL=postgres://usuario:senha@host:5432/promo

# Defina como "true" apenas se o Postgres estiver fora da rede interna e exigir TLS.
DATABASE_SSL=false

# Senha de administrador — quem souber isso edita o catálogo inteiro.
# Gere uma longa e aleatória, não reaproveite senha de outro serviço:
#   node -e "console.log(require('crypto').randomBytes(24).toString('base64url'))"
ADMIN_PASSWORD=

# Segredo usado para assinar o cookie de sessão. Se vazar, é possível forjar
# uma sessão de admin sem saber a senha. Trocar este valor desloga todo mundo.
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
SESSION_SECRET=
