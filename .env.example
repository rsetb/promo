# Caminho do arquivo SQLite.
# Em produção, aponte para DENTRO do volume persistente — se ficar fora, o
# catálogo é apagado a cada redeploy. No EasyPanel: monte um volume em /data
# e use /data/app.db.
DATABASE_PATH=./data/app.db

# Senha de administrador — quem souber isso edita o catálogo inteiro.
# Gere uma longa e aleatória, não reaproveite senha de outro serviço:
#   node -e "console.log(require('crypto').randomBytes(24).toString('base64url'))"
ADMIN_PASSWORD=

# Segredo usado para assinar o cookie de sessão. Se vazar, é possível forjar
# uma sessão de admin sem saber a senha. Trocar este valor desloga todo mundo.
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
SESSION_SECRET=
