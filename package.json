{
  "name": "nextn",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "tsx scripts/build-seed.ts && next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:studio": "drizzle-kit studio",
    "db:verify": "tsx scripts/verify-migration.ts",
    "db:seed": "tsx scripts/build-seed.ts",
    "db:setup": "tsx scripts/build-seed.ts && node scripts/migrate.mjs",
    "verify:format": "tsx scripts/verify-format.ts",
    "verify": "tsx scripts/verify-format.ts && tsx scripts/verify-uploads.ts && tsx scripts/verify-auth.ts && tsx scripts/verify-migration.ts",
    "verify:uploads": "tsx scripts/verify-uploads.ts",
    "verify:auth": "tsx scripts/verify-auth.ts"
  },
  "dependencies": {
    "@radix-ui/react-alert-dialog": "^1.1.6",
    "@radix-ui/react-dialog": "^1.1.6",
    "@radix-ui/react-dropdown-menu": "^2.1.6",
    "@radix-ui/react-label": "^2.1.2",
    "@radix-ui/react-select": "^2.1.6",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-toast": "^1.2.6",
    "better-sqlite3": "^12.11.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "lucide-react": "^0.475.0",
    "next": "15.5.9",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "server-only": "^0.0.1",
    "sharp": "^0.35.3",
    "tailwind-merge": "^3.0.1",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20",
    "@types/react": "^19.2.1",
    "@types/react-dom": "^19.2.1",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "tsx": "^4.23.1",
    "typescript": "^5"
  }
